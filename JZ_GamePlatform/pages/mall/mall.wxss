page {
  height: 100%;
  background: linear-gradient(180deg, #f5f3ff 0%, #fdfcf7 45%, #f3f7ff 100%);
}

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.top-bar {
  width: 100%;
  background: linear-gradient(135deg, #f3e7e9, #e3eeff);
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;
}

.nav-title-container {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  padding-left: 120rpx;
  padding-right: 120rpx;
  box-sizing: border-box;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #7a88b8;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #3b4256;
}

.content {
  height: 100vh;
  box-sizing: border-box;
  padding: 16rpx 28rpx 120rpx; /* 上边距由行内 padding-top: navHeight 决定，底部预留给 tabBar */
}

.balance-section {
  margin-bottom: 16rpx;
}

.balance-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 22rpx;
  background: radial-gradient(circle at 0% 0%, #fff7e5 0%, #e7f0ff 55%, #f4f3ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(170, 179, 210, 0.7);
  border: 1rpx solid rgba(244, 220, 170, 0.9);
  margin: 8rpx 0 0;
}

.balance-label {
  font-size: 24rpx;
  color: #7a88b8;
  margin-bottom: 6rpx;
}

.balance-main {
  margin: 4rpx 0 2rpx;
}

.balance-coin-circle {
  /* 改为扁平的横向信息，不再使用大圆圈 */
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.balance-coin-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #b45309;
}

.balance-coin-unit {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: #92400e;
}

.balance-footer {
  margin-top: 6rpx;
}

.balance-tip {
  font-size: 22rpx;
  color: #636b83;
  text-align: left;
}

.section-card {
  margin-top: 20rpx;
  border-radius: 20rpx;
  background: radial-gradient(circle at 0% 0%, #ffffff 0%, #fdf7f0 45%, #f3f4ff 100%);
  box-shadow: 0 12rpx 26rpx rgba(191, 196, 222, 0.7);
  border: 1rpx solid rgba(226, 219, 200, 0.8);
  padding: 18rpx 20rpx;
}

.section-header {
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b4256;
}

.goods-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.goods-main {
  flex: 1;
  padding-right: 10rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.goods-side {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.goods-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 22rpx rgba(15, 23, 42, 0.18);
  overflow: hidden;
}

/* 按类型区分的商品图标配色 */
.goods-icon.icon-postcard {
  background: linear-gradient(135deg, #fef3c7, #facc6b);
}

.goods-icon.icon-badge {
  background: linear-gradient(135deg, #fee2e2, #fb7185);
}

.goods-icon.icon-bag {
  background: linear-gradient(135deg, #e0f2fe, #60a5fa);
}

.goods-icon.icon-mug {
  background: linear-gradient(135deg, #ede9fe, #a855f7);
}

.goods-icon.icon-ticket {
  background: linear-gradient(135deg, #dcfce7, #22c55e);
}

.goods-icon.icon-cab {
  background: linear-gradient(135deg, #fef9c3, #facc15);
}

.goods-icon.icon-food {
  background: linear-gradient(135deg, #fee2cc, #fb923c);
}

.goods-icon.icon-coffee {
  background: linear-gradient(135deg, #f5e7dd, #c26b3a);
}

.goods-icon.icon-market {
  background: linear-gradient(135deg, #e0f2fe, #38bdf8);
}

.goods-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #3b4256;
}

.goods-cost {
  font-size: 24rpx;
  font-weight: 600;
  color: #b45309;
}

.goods-btn {
  font-size: 22rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #facc6b, #ffe7a8);
  color: #7c2d12;
}

.mall-note {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8b97c2;
  line-height: 1.6;
}

.more-coming {
  margin-top: 24rpx;
  text-align: center;
}
