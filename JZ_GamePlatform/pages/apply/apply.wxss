/* 继承原神淡色风的基础背景 */
page {
  height: 100%;
  background: linear-gradient(180deg, #f5f3ff 0%, #fdfcf7 45%, #f3f7ff 100%);
}

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.top-bar {
  width: 100%;
  background: linear-gradient(135deg, #f3e7e9, #e3eeff);
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;
}

.nav-title-container {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  padding-left: 120rpx;
  padding-right: 120rpx;
  box-sizing: border-box;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #7a88b8;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #3b4256;
}

.content {
  height: 100vh;
  box-sizing: border-box;
  padding: 16rpx 24rpx 120rpx; /* 上边距由行内 padding-top: navHeight 决定，底部预留给 tabBar */
}

.section-card {
  margin-bottom: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: radial-gradient(circle at 0% 0%, #ffffff 0%, #fdf7f0 45%, #f3f4ff 100%);
  box-shadow: 0 10rpx 24rpx rgba(191, 196, 222, 0.6);
  border: 1rpx solid rgba(226, 219, 200, 0.8);
}

.section-header {
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3b4256;
}

.step-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.step-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffe7b3, #facc6b);
  box-shadow: 0 8rpx 18rpx rgba(231, 176, 94, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #5b4630;
  margin-right: 12rpx;
}

.step-text-wrap {
  flex: 1;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b4256;
  margin-bottom: 4rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #636b83;
  line-height: 1.6;
}

.step-hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b97c2;
}

.field-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.field-main {
  flex: 1;
  padding-right: 12rpx;
}

.field-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #3b4256;
  margin-bottom: 2rpx;
}

.field-desc {
  font-size: 24rpx;
  color: #636b83;
  line-height: 1.5;
}

.field-input-wrapper {
  margin-top: 8rpx;
}

.field-input {
  width: 100%;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.7);
  background: rgba(249, 250, 251, 0.9);
  font-size: 24rpx;
  color: #111827;
}

.field-input::placeholder {
  color: #9ca3af;
}

.picker-display {
  line-height: 1.4;
}

.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.7);
  background: rgba(249, 250, 251, 0.9);
  font-size: 24rpx;
  color: #111827;
}

.field-textarea::placeholder {
  color: #9ca3af;
}

.field-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  white-space: nowrap;
}

.field-tag-required {
  background: rgba(220, 38, 38, 0.08);
  color: #b91c1c;
}

.field-tag-optional {
  background: rgba(56, 189, 248, 0.08);
  color: #0369a1;
}

.field-tag-auto {
  background: rgba(148, 163, 184, 0.16);
  color: #475569;
}

.status-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.status-badge {
  min-width: 96rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  text-align: center;
  margin-right: 12rpx;
}

.status-text {
  font-size: 24rpx;
  color: #636b83;
}

.status-pending {
  background: rgba(251, 191, 36, 0.12);
  color: #b45309;
}

.status-processing {
  background: rgba(59, 130, 246, 0.12);
  color: #1d4ed8;
}

.status-pass {
  background: rgba(16, 185, 129, 0.12);
  color: #047857;
}

.status-reject {
  background: rgba(248, 113, 113, 0.12);
  color: #b91c1c;
}

.status-archive {
  background: rgba(148, 163, 184, 0.12);
  color: #475569;
}

