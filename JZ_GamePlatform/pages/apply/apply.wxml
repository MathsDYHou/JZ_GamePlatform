<view class="page">
  <!-- 自定义导航栏 -->
  <view class="top-bar" style="height: {{navHeight}}px;">
    <view
      class="nav-title-container"
      style="top: {{titleTop}}px; height: 44px; line-height: 44px;"
    >
      <view class="nav-back" bindtap="goBack">‹</view>
      <text class="nav-title">活动申请</text>
    </view>
  </view>

  <!-- 页面内容：使用原生页面滚动，通过 padding-top 让内容从导航栏下方开始 -->
  <scroll-view
    class="content"
    scroll-y="true"
    show-scrollbar="true"
    enable-flex="true"
    style="padding-top: {{navHeight}}px; max-width: {{contentWidth}}px; margin: 0 auto;"
  >
    <!-- 步骤概览 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">流程概览</text>
      </view>
      <view class="step-row">
        <view class="step-badge">1</view>
        <view class="step-text-wrap">
          <view class="step-title">填写表格 -【提交】</view>
          <view class="step-desc">
            申请人按板块完整填写信息，确认无误后点击提交。
          </view>
        </view>
      </view>
      <view class="step-row">
        <view class="step-badge">2</view>
        <view class="step-text-wrap">
          <view class="step-title">提交后实时展示审核状态</view>
          <view class="step-desc">
            系统自动生成申请编号，状态流转为：待审核 → 审核中 → 审核通过 / 驳回 → 落地执行 → 结算归档。
          </view>
        </view>
      </view>
      <view class="step-hint">
        审核周期为 3-7 个工作日，如遇大型活动或特殊场景，周期可能顺延。
      </view>
    </view>

    <!-- 表格结构：基础信息 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">基础信息</text>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">申请人姓名 / 机构名称</view>
          <view class="field-input-wrapper">
            <input
              class="field-input"
              placeholder="个人：姓名 + 身份证号；机构：机构全称 + 统一社会信用代码。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">联系方式</view>
          <view class="field-input-wrapper">
            <input
              class="field-input"
              placeholder="手机号 + 常用邮箱，用于接收审核与沟通信息。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">申请人类型</view>
          <view class="field-input-wrapper">
            <picker
              mode="selector"
              range="{{applicantTypeOptions}}"
              value="{{applicantTypeIndex}}"
              bindchange="onApplicantTypeChange"
            >
              <view class="field-input picker-display">
                {{applicantTypeIndex === -1 ? '请选择申请人类型' : applicantTypeOptions[applicantTypeIndex]}}
              </view>
            </picker>
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">铁道印记等级</view>
          <view class="field-desc">系统自动匹配用户等级，等级越高审核优先级越高。</view>
        </view>
        <view class="field-tag field-tag-auto">系统</view>
      </view>
    </view>

    <!-- 活动核心信息 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">活动核心信息</text>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动名称</view>
          <view class="field-input-wrapper">
            <input
              class="field-input"
              placeholder="不超过 20 个字，简洁体现活动主题。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动类型</view>
          <view class="field-input-wrapper">
            <picker
              mode="selector"
              range="{{activityTypeOptions}}"
              value="{{activityTypeIndex}}"
              bindchange="onActivityTypeChange"
            >
              <view class="field-input picker-display">
                {{activityTypeIndex === -1 ? '请选择活动类型' : activityTypeOptions[activityTypeIndex]}}
              </view>
            </picker>
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动主题</view>
          <view class="field-input-wrapper">
            <picker
              mode="selector"
              range="{{activityThemeOptions}}"
              value="{{activityThemeIndex}}"
              bindchange="onActivityThemeChange"
            >
              <view class="field-input picker-display">
                {{activityThemeIndex === -1 ? '请选择活动主题' : activityThemeOptions[activityThemeIndex]}}
              </view>
            </picker>
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动层级</view>
          <view class="field-input-wrapper">
            <picker
              mode="selector"
              range="{{activityLevelOptions}}"
              value="{{activityLevelIndex}}"
              bindchange="onActivityLevelChange"
            >
              <view class="field-input picker-display">
                {{activityLevelIndex === -1 ? '请选择活动层级' : activityLevelOptions[activityLevelIndex]}}
              </view>
            </picker>
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动时间</view>
          <view class="field-input-wrapper">
            <input
              class="field-input"
              placeholder="请填写开始时间 + 结束时间，含筹备期、执行期与撤场期。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动场地需求</view>
          <view class="field-input-wrapper">
            <textarea
              class="field-textarea"
              placeholder="可填写：站台实验室 / 车厢工作室 / 轨道创想区 / 草坪区 / 漂浮盒子集群 / 其他点位，以及面积与设备需求。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">参与人数规模</view>
          <view class="field-input-wrapper">
            <input
              class="field-input"
              placeholder="请填写预计参与人数上限与受众人群定位。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">是否收费</view>
          <view class="field-input-wrapper">
            <picker
              mode="selector"
              range="{{chargeOptions}}"
              value="{{chargeIndex}}"
              bindchange="onChargeChange"
            >
              <view class="field-input picker-display">
                {{chargeIndex === -1 ? '请选择是否收费' : chargeOptions[chargeIndex]}}
              </view>
            </picker>
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
    </view>

    <!-- 活动详情方案 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">活动详情方案</text>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动内容简介</view>
          <view class="field-input-wrapper">
            <textarea
              class="field-textarea"
              placeholder="300 字以内，说明核心流程、内容亮点，与公园定位的契合度。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动执行流程</view>
          <view class="field-input-wrapper">
            <textarea
              class="field-textarea"
              placeholder="请分阶段填写筹备、执行、撤场的关键环节与时间节点。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">物料与设备需求</view>
          <view class="field-input-wrapper">
            <textarea
              class="field-textarea"
              placeholder="需公园提供的硬件设备、基础物料、技术支持，如无可填“无”。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-optional">选填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">宣传推广需求</view>
          <view class="field-input-wrapper">
            <textarea
              class="field-textarea"
              placeholder="需公园官方渠道支持的宣传资源，如无可填“无”。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-optional">选填</view>
      </view>
    </view>

    <!-- 合作与合规信息 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">合作与合规信息</text>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">合作模式诉求</view>
          <view class="field-input-wrapper">
            <picker
              mode="selector"
              range="{{coopModeOptions}}"
              value="{{coopModeIndex}}"
              bindchange="onCoopModeChange"
            >
              <view class="field-input picker-display">
                {{coopModeIndex === -1 ? '请选择合作模式' : coopModeOptions[coopModeIndex]}}
              </view>
            </picker>
            <textarea
              class="field-textarea"
              placeholder="请补充具体合作诉求与说明。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">风险防控方案</view>
          <view class="field-input-wrapper">
            <textarea
              class="field-textarea"
              placeholder="请填写活动安全预案、人流管控方案、应急处理措施等。"
            />
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">合规承诺</view>
          <view class="field-input-wrapper">
            <view class="field-desc">
              申请人确认活动内容符合国家法律法规、公园管理规定与共创公约，无侵权内容，提交即视为同意。
            </view>
          </view>
        </view>
        <view class="field-tag field-tag-required">必填</view>
      </view>
    </view>

    <!-- 附件上传 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">附件上传</text>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">活动详细方案 PPT</view>
          <view class="field-desc">限 50MB 以内，PDF / PPT 格式。</view>
        </view>
        <view class="field-tag field-tag-optional">选填（大型活动必填）</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">相关资质证明</view>
          <view class="field-desc">机构资质、演出许可、师资证明等，图片 / PDF 格式。</view>
        </view>
        <view class="field-tag field-tag-optional">选填（按类型要求）</view>
      </view>
      <view class="field-row">
        <view class="field-main">
          <view class="field-name">过往案例</view>
          <view class="field-desc">同类型活动落地案例，图片 / PDF 格式。</view>
        </view>
        <view class="field-tag field-tag-optional">选填</view>
      </view>
    </view>

    <!-- 审核状态说明 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">审核状态说明</text>
      </view>
      <view class="status-row">
        <view class="status-badge status-pending">待审核</view>
        <text class="status-text">提交成功，等待运营方初审。</text>
      </view>
      <view class="status-row">
        <view class="status-badge status-processing">审核中</view>
        <text class="status-text">初审通过，进入方案评估与场地排期确认。</text>
      </view>
      <view class="status-row">
        <view class="status-badge status-pass">审核通过</view>
        <text class="status-text">方案与排期确认，发放场地使用许可证，可进入筹备阶段。</text>
      </view>
      <view class="status-row">
        <view class="status-badge status-reject">驳回</view>
        <text class="status-text">标注驳回原因，申请人可修改后重新提交。</text>
      </view>
      <view class="status-row">
        <view class="status-badge status-archive">归档</view>
        <text class="status-text">活动完成并提交结案报告后，完成结算与评价归档。</text>
      </view>
    </view>
  </scroll-view>
</view>

