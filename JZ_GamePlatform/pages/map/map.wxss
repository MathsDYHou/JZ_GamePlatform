/* 延续全局淡色背景，保留简单顶部导航与地图区域 */
page {
  height: 100%;
  background: linear-gradient(180deg, #f5f3ff 0%, #fdfcf7 45%, #f3f7ff 100%);
}

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.top-bar {
  width: 100%;
  background: linear-gradient(135deg, #f3e7e9, #e3eeff);
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;
}

.nav-title-container {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  padding-left: 120rpx;
  padding-right: 120rpx;
  box-sizing: border-box;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #3b4256;
}

.content {
  padding: 16rpx 24rpx 160rpx; /* 底部多预留一些，让下方信息卡远离底部导航栏 */
  box-sizing: border-box;
}

.map-container {
  position: relative;
}

.map-image {
  width: 100%;
}

.map-side-toolbar {
  position: fixed;
  left: 24rpx;
  top: 0; /* 实际 top 由行内 style 使用 navHeight 动态控制 */
  width: 120rpx;
  padding: 8rpx 0;
  border-radius: 32rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(249, 250, 251, 0.92));
  box-shadow: 0 12rpx 32rpx rgba(148, 163, 184, 0.65);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  z-index: 900;
}

.toolbar-item {
  width: 100%;
  padding: 10rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.toolbar-item-active {
  background: linear-gradient(180deg, #fed7aa, #fee2b3);
  border-radius: 28rpx;
  margin-bottom: 4rpx;
}

.toolbar-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  margin-bottom: 4rpx;
}

.toolbar-icon-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #4b5563;
  margin-bottom: 4rpx;
  background: rgba(255, 255, 255, 0.9);
}

.toolbar-text {
  font-size: 22rpx;
  color: #374151;
}

.toolbar-divider {
  width: 70%;
  height: 1rpx;
  background: rgba(148, 163, 184, 0.4);
}

.popup-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.45);
  z-index: 2000;
  display: flex;
  align-items: center; /* 弹窗垂直居中 */
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.popup-card {
  width: 100%;
  max-width: 640rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 20rpx 60rpx rgba(15, 23, 42, 0.35);
  padding: 20rpx 20rpx 18rpx;
  box-sizing: border-box;
  max-height: 80vh; /* 避免内容过长被底部遮挡 */
  overflow-y: auto;
}

.popup-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.popup-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.popup-status {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: rgba(16, 185, 129, 0.14);
  color: #047857;
}

.popup-grid {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.popup-field {
  padding: 12rpx 12rpx;
  border-radius: 18rpx;
  background: rgba(148, 163, 184, 0.12);
}

.popup-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.popup-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.popup-subvalue {
  margin-top: 2rpx;
  font-size: 22rpx;
  color: #4b5563;
}

.popup-detail {
  margin-top: 12rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.35);
}

.popup-detail-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.popup-detail-action {
  font-size: 24rpx;
  color: #2563eb;
}

.popup-detail-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

.popup-actions {
  margin-top: 14rpx;
}

.popup-btn {
  width: 100%;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #facc6b, #ffe7a8);
  color: #7c2d12;
  font-weight: 700;
}

.center-marker {
  position: absolute;
  left: 50%;
  top: 55%; /* 上移一些，让大头钉更接近地图中心 */
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.marker-head {
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.4);
  overflow: hidden;
}

.marker-head-img {
  width: 100%;
  height: 100%;
}

.marker-tail-wrapper {
  position: relative;
  width: 0;
  height: 0;
  border-left: 32rpx solid transparent;
  border-right: 32rpx solid transparent;
  border-top: 50rpx solid #ffffff; /* 外层白色边框三角 */
}

.map-info-card {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.5);
}

.map-info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
  text-align: center; /* 当前区域标题居中 */
}

.map-info-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-top: 8rpx;
}

.map-info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center; /* 每个模块在各自三分之一区域内居中 */
}

.map-info-item-label {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 2rpx;
}

.map-info-item-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

