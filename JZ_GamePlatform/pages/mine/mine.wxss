/* 继承原神淡色主题 */
page {
  height: 100%;
  background: linear-gradient(180deg, #f5f3ff 0%, #fdfcf7 45%, #f3f7ff 100%);
}

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.top-bar {
  width: 100%;
  background: linear-gradient(135deg, #f3e7e9, #e3eeff);
  position: fixed;
  top: 0;
  left: 0;
  z-index: 1000;
}

.nav-title-container {
  position: absolute;
  left: 0;
  right: 0;
  text-align: center;
  padding-left: 120rpx;
  padding-right: 120rpx;
  box-sizing: border-box;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  color: #3b4256;
}

.content {
  padding: 16rpx 24rpx 120rpx;
}

.profile-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background: radial-gradient(circle at 0% 0%, #fff7e5 0%, #e7f0ff 45%, #f4f3ff 100%);
  box-shadow: 0 18rpx 38rpx rgba(170, 179, 210, 0.8);
  border: 1rpx solid rgba(244, 220, 170, 0.9);
  margin-bottom: 24rpx;
}

.profile-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.profile-right {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.avatar-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 20% 0%, #ffe7b3 0%, #facc6b 35%, #fbbf24 80%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14rpx 28rpx rgba(231, 176, 94, 0.9);
  margin-right: 18rpx;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #5b4630;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #3b4256;
  margin-bottom: 4rpx;
}

.profile-subline {
  font-size: 24rpx;
  color: #636b83;
}

.coin-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #facc6b, #ffe7a8);
  box-shadow: 0 10rpx 22rpx rgba(225, 170, 75, 0.9);
}

.coin-pill-label {
  font-size: 22rpx;
  color: #92400e;
  margin-right: 6rpx;
}

.coin-pill-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #7c2d12;
}


.menu-card {
  border-radius: 20rpx;
  background: radial-gradient(circle at 0% 0%, #ffffff 0%, #fdf7f0 45%, #f3f4ff 100%);
  box-shadow: 0 12rpx 26rpx rgba(191, 196, 222, 0.7);
  border: 1rpx solid rgba(226, 219, 200, 0.8);
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 20rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid rgba(226, 219, 200, 0.8);
}

.menu-left {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.menu-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
}

.menu-icon-task {
  background: linear-gradient(135deg, #9cc7ff, #c1d9ff);
}

.menu-icon-badge {
  background: linear-gradient(135deg, #ffe0a3, #ffd8b3);
}

.menu-icon-coin {
  background: linear-gradient(135deg, #a5e2c5, #d3f7d8);
}

.menu-text-main {
  font-size: 26rpx;
  color: #3b4256;
}

.menu-arrow {
  font-size: 28rpx;
  color: #c0c4d4;
}

/* 我的功能模块区：直接复用创制工坊的模块卡片风格 */
.module-grid {
  padding: 8rpx 0 0;
  display: flex;
  flex-direction: column;
  row-gap: 16rpx;
}

.module-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: radial-gradient(circle at 0% 0%, #ffffff 0%, #fdf7f0 45%, #f3f4ff 100%);
  box-shadow: 0 14rpx 30rpx rgba(191, 196, 222, 0.6);
  border: 1rpx solid rgba(226, 219, 200, 0.8);
}

.module-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 18rpx;
}

.module-icon-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.icon-m-task {
  background: linear-gradient(135deg, #9cc7ff, #c1d9ff);
  box-shadow: 0 10rpx 22rpx rgba(148, 178, 238, 0.7);
}

.icon-m-mall {
  background: linear-gradient(135deg, #facc6b, #ffe7a8);
  box-shadow: 0 10rpx 22rpx rgba(225, 170, 75, 0.7);
}

.icon-m-mark {
  background: linear-gradient(135deg, #a5e2c5, #d3f7d8);
  box-shadow: 0 10rpx 22rpx rgba(107, 196, 150, 0.7);
}

.icon-m-project {
  background: linear-gradient(135deg, #ffe0a3, #ffd8b3);
  box-shadow: 0 10rpx 22rpx rgba(231, 176, 94, 0.7);
}

.module-info {
  flex: 1;
}

.module-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #3b4256;
  margin-bottom: 4rpx;
}

.module-desc {
  font-size: 26rpx;
  color: #636b83;
  line-height: 1.5;
}
